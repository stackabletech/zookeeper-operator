      if ! diff_out=$(diff -u "$expected_file" "$actual_file"); then
        echo "ERROR: ConfigMap test-zk-server-secondary data drifted from snapshot."
        printf '%s\n' "$diff_out"
        rm -f "$expected_file" "$actual_file"
